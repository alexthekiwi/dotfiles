# --- Caretakers AWS bastion (fixed-IP jumphost; EIP 3.102.104.3) ---
# Reach the bastion over Tailscale; auth is Tailscale SSH (no key needed).
# accept-new avoids a host-key prompt blocking non-interactive tools (TablePlus).
Host bastion caretakers-bastion
    HostName caretakers-bastion.taila4aa39.ts.net
    User ec2-user
    StrictHostKeyChecking accept-new

# Hosts reached *through* the bastion so they egress the whitelisted EIP.
# No IdentityFile, so they keep using your laptop's key via the 1Password agent
# (the global "Host *" block). ProxyJump only changes transport, not auth: your
# laptop authenticates end-to-end to the target; the bastion never sees the key.
# Each is keyed on its raw IP too, so TablePlus "Over SSH" and `ssh forge@<ip>`
# still match and route through the bastion automatically.

# Star Insure prod VM  -> ODSPRD / REPPRD databases
Host sis-prod star-odsprd 20.213.24.251
    HostName 20.213.24.251
    User forge
    ProxyJump bastion

