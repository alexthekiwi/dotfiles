#!/usr/bin/env bash

HISTORY_FILE="$HOME/.local/share/tmux-sessionizer-history"
touch "$HISTORY_FILE"

if [[ $# -eq 1 ]]; then
    selected=$1
else
    # Extra non-Code dirs to make sessionizable (scratch/reading dirs).
    # Only included if they exist — keeps the list clean on machines (e.g. the
    # Mac Mini) where the Synology wiki mount isn't present.
    extra_dirs=(
        "$HOME/Downloads"
        "$HOME/Library/CloudStorage/SynologyDrive-Caretakers/brain/wiki"
    )
    existing_extra=()
    for d in "${extra_dirs[@]}"; do
        [[ -d $d ]] && existing_extra+=("$d")
    done
    all_dirs=$( { find ~/Code -mindepth 1 -maxdepth 1 -type d; printf '%s\n' "${existing_extra[@]}"; } | sort)
    # Dirs ordered by most recently sessionized (most recent last)
    ranked=$(tac "$HISTORY_FILE" | awk '!seen[$0]++')
    # Unranked dirs go at the top
    unranked=$(comm -23 <(echo "$all_dirs") <(echo "$ranked" | sort))
    selected=$(printf '%s\n%s' "$unranked" "$(echo "$ranked" | tac)" | grep -v '^$' | fzf --tac)
fi

if [[ -z $selected ]]; then
    exit 0
fi

# Log this selection
echo "$selected" >> "$HISTORY_FILE"

selected_name=$(basename "$selected" | tr . _)

if ! tmux has-session -t="$selected_name" 2> /dev/null; then
    tmux new-session -ds "$selected_name" -c "$selected" -n code
    tmux send-keys -t "$selected_name:code" "nvim" Enter
    tmux new-window -t "$selected_name" -n agents -c "$selected"
    tmux split-window -t "$selected_name:agents" -h -c "$selected"
    tmux new-window -t "$selected_name" -n processes -c "$selected"
    tmux split-window -t "$selected_name:processes" -h -c "$selected"
    tmux split-window -t "$selected_name:processes" -v -c "$selected"
    tmux select-pane -t "$selected_name:processes.1"
    tmux select-window -t "$selected_name:code"
fi

tmux switch-client -t "$selected_name"
